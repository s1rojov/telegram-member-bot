# ─── Telegram MTProto API (my.telegram.org dan oling) ───────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── Userbot telefon raqami (+ bilan, masalan: +998901234567) ────────────────
TELEGRAM_PHONE=

# ─── Session kaliti (birinchi ishga tushganda consolda chiqadi, shu yerga ko'chiring) ─
TELEGRAM_SESSION=

# ─── Manba kanallar ID lari (vergul bilan ajratilgan, masalan: -1001234567890,-1009876543210) ─
SOURCE_CHANNEL_IDS=

# ─── Maqsadli kanal ID si (post yuboriladigan kanal) ────────────────────────
DESTINATION_CHANNEL_ID=

# ─── PostgreSQL ulanish URL si ───────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/forwarder_db
